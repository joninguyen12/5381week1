# Copy to .env for local runs (optional) and for deployme.sh (Connect only — see below).

# --- Posit Connect (used by deployme.sh / manifestme.sh) ---
# CONNECT_SERVER=https://connect.example.com
# CONNECT_API_KEY=your-api-key-from-connect
# Optional:
# CONNECT_TITLE=pokedex-explorer
# CONNECT_PYTHON_VERSION=3.12.4

# --- App AI (optional — or set as secrets on the Connect server) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# Optional (only if your Ollama is behind an authenticated gateway / reverse proxy):
# OLLAMA_API_KEY=
# OLLAMA_API_KEY_HEADER=Authorization
